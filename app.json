{
  "expo": {
    "name": "DevCard",
    "slug": "devcard",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0f172a"
    },
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0f172a"
      }
    },
    "scheme": "devcard",
    "plugins": [
      "expo-router",
      "expo-asset"
    ]
  }
}
